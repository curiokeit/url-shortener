@model UrlShortener.Web.Models.DashboardViewModel

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Dashboard</h2>
            <p class="text-muted mb-0">Manage your short links and track performance.</p>
        </div>

        <div>
            <a href="/Links/Create" class="btn btn-primary">+ Create Link</a>
            <a href="/Auth/Logout" class="btn btn-outline-danger">Logout</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Total Links</p>
                    <h3 class="fw-bold">@Model.TotalLinks</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Total Clicks</p>
                    <h3 class="fw-bold">@Model.TotalClicks</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Active Links</p>
                    <h3 class="fw-bold text-success">@Model.ActiveLinks</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Expired Links</p>
                    <h3 class="fw-bold text-danger">@Model.ExpiredLinks</h3>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Links.Any())
    {
        <div class="alert alert-info">
            No links created yet. Create your first short link to see analytics here.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0">My Links</h5>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Original URL</th>
                            <th>Short Code</th>
                            <th>Clicks</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var link in Model.Links)
                        {
                            var isExpired = link.ExpireAt.HasValue && link.ExpireAt.Value <= DateTime.UtcNow;

                            <tr>
                                <td style="max-width: 340px; word-break: break-all;">
                                    <a href="@link.OriginalUrl" target="_blank" class="text-decoration-none">
                                        @link.OriginalUrl
                                    </a>
                                </td>

                                <td>
                                    <a href="@link.ShortUrl" target="_blank" class="badge bg-primary text-decoration-none">
                                        @link.ShortCode
                                    </a>
                                </td>

                                <td>
                                    <span class="badge bg-dark">@link.ClickCount</span>
                                </td>

                                <td>
                                    @if (isExpired)
                                    {
                                        <span class="badge bg-danger">Expired</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                </td>

                                <td>@link.CreatedAt.ToShortDateString()</td>

                                <td class="text-end">
                                    <a href="/Links/Stats/@link.Id" class="btn btn-sm btn-outline-primary">Stats</a>
                                    <a href="/Links/Delete/@link.Id" class="btn btn-sm btn-outline-danger"
                                           onclick="return confirm('Are you sure you want to delete this link?');">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>