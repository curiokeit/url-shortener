@model UrlShortener.Web.Models.CreateLinkViewModel

<div class="container mt-5">
    <div class="card shadow p-4 mx-auto" style="max-width: 600px;">
        <h2 class="mb-4">Create Short Link</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form method="post">
            <div class="mb-3">
                <label>Original URL</label>
                <input asp-for="OriginalUrl" class="form-control" placeholder="https://example.com" />
            </div>

            <div class="mb-3">
                <label>Custom Code</label>
                <input asp-for="CustomCode" class="form-control" placeholder="my-link" />
                <small class="text-muted">Optional</small>
            </div>

            <div class="mb-3">
                <label>Expire At</label>
                <input asp-for="ExpireAt" type="datetime-local" class="form-control" />
                <small class="text-muted">Optional</small>
            </div>

            <button class="btn btn-primary w-100">Create</button>
        </form>

        <div class="mt-3">
            <a href="/Links/Index">Back to links</a>
        </div>
    </div>
</div>